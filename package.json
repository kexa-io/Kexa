{
    "name": "kexa",
    "description": "Open-source multi-cloud compliance management tool",
    "module": "main.ts",
    "type": "module",
    "version": "2.8.1",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/kexa-io/Kexa.git"
    },
    "homepage": "https://www.kexa.io",
    "bugs": {
        "url": "https://github.com/kexa-io/Kexa/issues"
    },
    "author": "Kexa.io <contact@kexa.io>",
    "keywords": [
        "cloud-compliance",
        "security",
        "finops",
        "multi-cloud",
        "azure",
        "aws",
        "gcp",
        "kubernetes",
        "cspm"
    ],
    "license": "Apache-2.0",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "latest",
        "eslint": "^10.1.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-unicorn": "^63.0.0",
        "prettier": "^3.8.1",
        "typescript-eslint": "^8.58.0"
    },
    "scripts": {
        "start": "bun run Kexa/main.js",
        "lint": "eslint",
        "build": "rimraf ./build && touch ./config/headers.json && bun build ./Kexa/main.ts --target bun --outdir ./build",
        "update:capability": "bun run build && bun ./build/services/updateCapability.service.js",
        "test": "bun run build && bun test Kexa/__tests__/**/*.test.ts",
        "test:nobuild": "bun test Kexa/__tests__/**/*.test.ts",
        "test:integration": "bun test ./Kexa/__tests__/integration/"
    },
    "peerDependencies": {
        "typescript": "^4.9.5"
    },
    "release": {
        "branches": [
            "main"
        ],
        "plugins": [
            "@semantic-release/commit-analyzer",
            "@semantic-release/release-notes-generator",
            "@semantic-release/changelog",
            "@semantic-release/github",
            [
                "@semantic-release/git",
                {
                    "assets": [
                        "CHANGELOG.md"
                    ],
                    "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
                }
            ],
            [
                "@semantic-release/exec",
                {
                    "publishCmd": "echo ::set-output name=nextVer::${nextRelease.version}"
                }
            ]
        ]
    },
